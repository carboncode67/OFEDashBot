# OFEDashBot — Environment Template
# =================================
# Copy this file to ".env" and fill in real values. Never commit ".env".
#   cp .env.example .env
#
# Generate a strong session secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# --- Twilio (WhatsApp Business) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Sandbox default shown; replace with your approved WhatsApp sender in production.
TWILIO_WHATSAPP_NUMBER=whatsapp:+11234567890

# --- Admin ---
# Phone that receives startup/shutdown and error alerts (digits only, with country code).
ADMIN_PHONE=16070000000
# Password for the admin desktop app and processing GUI. CHANGE THIS.
ADMIN_PASSWORD=change-me

# --- Session signing (admin/student GUI cookies) ---
SESSION_SECRET=change-this-secret-before-deployment

# --- Security ---
# Must be true in production. False is allowed only for local development.
VALIDATE_TWILIO_SIGNATURE=false
MAX_UPLOAD_MB=64

# --- Storage ---
BASE_DIR=received

# --- FDL backend integration ---
# Base URL of the FDL Dashboard API that receives forwarded submissions.
FDL_API_URL=http://localhost:3000
# Optional service token for OFEDashBot's own reads (e.g. the contacts list).
FDL_SERVICE_TOKEN=

# --- Environment ---
# "development" or "production". Production enables the startup safety checks.
ENVIRONMENT=development
